{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2020",
    "noEmit": true
  },
  "include": ["src", "vite-env.d.ts"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
