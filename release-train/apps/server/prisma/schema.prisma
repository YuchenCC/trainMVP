generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String            @id @default(cuid())
  username            String            @unique
  displayName         String
  email               String            @unique
  password            String?
  role                Role              @default(BA)
  ssoId               String?           @unique
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  emergencyApprovals  EmergencyChange[] @relation("Approver")
  ownedRequirements   Requirement[]     @relation("BA")
  createdRequirements Requirement[]     @relation("Creator")
  pmRequirements      Requirement[]     @relation("PM")
  statusLogs          StatusLog[]       @relation("StatusOperator")
  systemMembers       SystemMember[]
  createdTrains       Train[]           @relation("TrainCreator")
  createdSchedules    TrainSchedule[]   @relation("ScheduleCreator")
}

model System {
  id             String                @id @default(cuid())
  name           String                @unique
  description    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  changeRequests ChangeRequest[]
  requirements   Requirement[]
  members        SystemMember[]
  trainSystems   TrainSystem?
  snapshots      TrainSystemSnapshot[]
}

model SystemMember {
  id       String     @id @default(cuid())
  systemId String
  userId   String
  role     SystemRole @default(DEV)
  system   System     @relation(fields: [systemId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([systemId, userId, role])
}

model Requirement {
  id               String                  @id @default(cuid())
  reqCode          String                  @unique
  title            String
  description      String
  systemId         String
  priority         Priority
  storyPoints      Int
  baId             String
  pmId             String?
  creatorId        String
  status           ReqStatus               @default(DRAFT)
  subStatus        ReqSubStatus?
  version          Int                     @default(1)
  reqType          ReqType?
  sourceChannel    SourceChannel?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  scheduleId       String?
  changeRequests   ChangeRequest[]
  emergencyChanges EmergencyChange[]
  ba               User                    @relation("BA", fields: [baId], references: [id])
  creator          User                    @relation("Creator", fields: [creatorId], references: [id])
  pm               User?                   @relation("PM", fields: [pmId], references: [id])
  trainSchedule    TrainSchedule?          @relation(fields: [scheduleId], references: [id])
  system           System                  @relation(fields: [systemId], references: [id])
  dependants       RequirementDependency[] @relation("DependantRequirement")
  dependencies     RequirementDependency[] @relation("DependencyRequirement")
  statusLogs       StatusLog[]

  @@index([status, subStatus])
  @@index([systemId])
  @@index([baId])
  @@index([scheduleId])
  @@index([priority])
}

model RequirementDependency {
  id           String      @id @default(cuid())
  dependantId  String
  dependencyId String
  dependant    Requirement @relation("DependantRequirement", fields: [dependantId], references: [id], onDelete: Cascade)
  dependency   Requirement @relation("DependencyRequirement", fields: [dependencyId], references: [id], onDelete: Cascade)

  @@unique([dependantId, dependencyId])
  @@index([dependencyId])
}

model StatusLog {
  id            String        @id @default(cuid())
  requirementId String
  operationType OperationType
  fromStatus    ReqStatus?
  toStatus      ReqStatus
  fromSubStatus ReqSubStatus?
  toSubStatus   ReqSubStatus?
  reason        String?
  operatorId    String
  createdAt     DateTime      @default(now())
  operator      User          @relation("StatusOperator", fields: [operatorId], references: [id])
  requirement   Requirement   @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId, createdAt(sort: Desc)])
}

model Train {
  id           String          @id @default(cuid())
  name         String
  description  String?
  createdById  String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  version      Int             @default(1)
  createdBy    User            @relation("TrainCreator", fields: [createdById], references: [id])
  schedules    TrainSchedule[]
  trainSystems TrainSystem[]
}

model TrainSchedule {
  id           String                 @id @default(cuid())
  trainId      String
  name         String
  status       TrainScheduleStatus    @default(PLANNING)
  startDate    DateTime?
  endDate      DateTime?
  boardingDate DateTime?
  lockdownDate DateTime?
  releaseDate  DateTime?
  version      Int                    @default(1)
  createdById  String
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  sitDate      DateTime?
  uatDate      DateTime?
  requirements Requirement[]
  createdBy    User                   @relation("ScheduleCreator", fields: [createdById], references: [id])
  train        Train                  @relation(fields: [trainId], references: [id], onDelete: Cascade)
  keyDates     TrainScheduleKeyDate[]
  snapshots    TrainSystemSnapshot[]

  @@index([trainId, createdAt(sort: Desc)])
}

model TrainSystem {
  id             String   @id @default(cuid())
  trainId        String
  systemId       String   @unique
  capacityPoints Int      @default(0)
  usedPoints     Int      @default(0)
  baUserId       String?
  pmUserId       String?
  techMgrUserId  String?
  testMgrUserId  String?
  devTeamUserIds String[] @default([])
  system         System   @relation(fields: [systemId], references: [id], onDelete: Cascade)
  train          Train    @relation(fields: [trainId], references: [id], onDelete: Cascade)

  @@unique([trainId, systemId])
  @@index([trainId])
}

model TrainSystemSnapshot {
  id              String        @id @default(cuid())
  trainScheduleId String
  systemId        String
  capacityPoints  Int           @default(0)
  usedPoints      Int           @default(0)
  baUserId        String?
  pmUserId        String?
  techMgrUserId   String?
  testMgrUserId   String?
  devTeamUserIds  String[]      @default([])
  createdAt       DateTime      @default(now())
  system          System        @relation(fields: [systemId], references: [id], onDelete: Cascade)
  trainSchedule   TrainSchedule @relation(fields: [trainScheduleId], references: [id], onDelete: Cascade)

  @@unique([trainScheduleId, systemId])
  @@index([trainScheduleId])
}

model TrainScheduleKeyDate {
  id              String        @id @default(cuid())
  trainScheduleId String
  name            String
  date            DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  trainSchedule   TrainSchedule @relation(fields: [trainScheduleId], references: [id], onDelete: Cascade)

  @@index([trainScheduleId])
}

model EmergencyChange {
  id            String         @id @default(cuid())
  requirementId String
  urgency       UrgencyLevel
  reason        String
  status        ApprovalStatus @default(PENDING)
  approverId    String?
  approvedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime       @default(now())
  approvalStep  Int            @default(1)
  approver      User?          @relation("Approver", fields: [approverId], references: [id])
  requirement   Requirement    @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([status, approverId])
}

model ChangeRequest {
  id              String      @id @default(cuid())
  changeCode      String      @unique
  requirementId   String
  systemId        String
  conversation    String?
  changeSummary   String?
  workloadImpact  String?
  scheduleImpact  String?
  riskLevel       String?     @default("低")
  riskDescription String?
  status          String      @default("PENDING")
  source          String      @default("coze")
  confirmedBy     String?
  confirmedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  requirement     Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  system          System      @relation(fields: [systemId], references: [id])

  @@index([requirementId, createdAt(sort: Desc)])
  @@index([systemId])
}

enum Role {
  BA
  PM
  PROJECT_MGR
  TECH_MGR
  TEST_MGR
  TRAIN_ADMIN
  SUPER_ADMIN
}

enum SystemRole {
  BA
  PM
  PROJECT_MGR
  TECH_MGR
  TEST_MGR
  DEV
  QA
}

enum Priority {
  P0
  P1
  P2
  P3
}

enum ReqType {
  NEW_FEATURE
  OPTIMIZATION
  BUG
}

enum SourceChannel {
  BUSINESS
  USER_FEEDBACK
  DATA_ANALYSIS
  COMPETITOR
}

enum ReqStatus {
  DRAFT
  PENDING_REVIEW
  READY
  REJECTED
  ONBOARDED
  RELEASED
  CANCELLED
}

enum ReqSubStatus {
  DEV_IN_PROGRESS
  SIT_TESTING
  UAT_TESTING
  FROZEN
}

enum OperationType {
  CREATE
  UPDATE
  SUBMIT_REVIEW
  REVIEW_PASS
  REVIEW_REJECT
  RE_EDIT
  CANCEL
  CHANGE_REQUIREMENT
  EMERGENCY_CHANGE
  DEV_COMPLETE
  SIT_PASS
  UAT_PASS
  BATCH_SUBMIT_REVIEW
  BATCH_CANCEL
  BATCH_CHANGE_PRIORITY
  ONBOARD
  REMOVE
  RELEASE
  ROLLBACK
  CHANGE_SUB_STATUS
}

enum TrainScheduleStatus {
  PLANNING
  IN_PROGRESS
  LOCKED_DOWN
  RELEASED
}

enum UrgencyLevel {
  P0
  P1
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}
